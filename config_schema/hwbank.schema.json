{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "fitom-hwbank",
  "title": "FITOM HW パッチバンク (*.hwbank.json)",
  "description": "チップレジスタへ直接書き込むパラメータのバンク。チップ族ごとに独立したファイルで管理する。",
  "type": "object",
  "required": [
    "name",
    "patches"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "バンク表示名"
    },
    "chip_group": {
      "type": "string",
      "enum": [
        "OPM",
        "OPN",
        "OPL2",
        "OPL3",
        "OPLL",
        "PSG",
        "PCM"
      ],
      "description": "対象チップ族。ロード時の VoiceGroup 解決に使用。"
    },
    "patches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "prog"
        ],
        "properties": {
          "prog": {
            "type": "integer",
            "minimum": 0,
            "maximum": 127
          },
          "name": {
            "type": "string"
          },
          "FB": {
            "type": "integer",
            "minimum": 0,
            "maximum": 7,
            "description": "Feedback"
          },
          "ALG": {
            "type": "integer",
            "minimum": 0,
            "maximum": 7,
            "description": "Algorithm"
          },
          "AMS": {
            "type": "integer",
            "minimum": 0,
            "maximum": 3,
            "description": "AM Sensitivity (OPM)"
          },
          "PMS": {
            "type": "integer",
            "minimum": 0,
            "maximum": 7,
            "description": "PM Sensitivity (OPM)"
          },
          "NFQ": {
            "type": "integer",
            "minimum": 0,
            "maximum": 31,
            "description": "Noise Frequency (OPM)"
          },
          "ops": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": {
              "type": "object",
              "properties": {
                "AR": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 31
                },
                "DR": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 31
                },
                "SL": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 15
                },
                "SR": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 31
                },
                "RR": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 15
                },
                "TL": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 127
                },
                "KSR": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 3
                },
                "KSL": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 3
                },
                "MUL": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 15
                },
                "DT1": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 7
                },
                "DT2": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 3
                },
                "AM": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1
                },
                "VIB": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1
                },
                "EGT": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 15,
                  "description": "SSG-EG (OPN)"
                },
                "WS": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 7,
                  "description": "Wave Select (OPL/OPZ)"
                },
                "FXV": {
                  "type": "integer",
                  "minimum": -32768,
                  "maximum": 32767,
                  "description": "OPN ch2 FXモード(3rd channel special mode)専用パラメータ。ext.DM0でモード選択。モード1/2(疑似デチューン/非整数倍率): 100/64セント単位の符号付きオフセット。モード3(固定周波数): 0.1Hz単位の絶対周波数。OPN以外・ch2以外では無視。"
                }
              }
            }
          },
          "ext": {
            "type": "object",
            "description": "チップ固有拡張パラメータ (OPZ / PSG 等)",
            "properties": {
              "REV": {
                "type": "integer",
                "minimum": 0,
                "maximum": 15
              },
              "EGS": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127
              },
              "DM0": {
                "type": "integer",
                "minimum": 0,
                "maximum": 3,
                "description": "OPZ: Osc fixed freq flag(1bit相当、0/1)。OPN ch2: FXモード選択 (0=通常/1=疑似デチューン/2=非整数倍率/3=固定周波数)。他チップでは未使用。"
              },
              "DT3": {
                "type": "integer",
                "minimum": 0,
                "maximum": 15
              },
              "ALG_EXT": {
                "type": "integer",
                "minimum": 0,
                "maximum": 1
              },
              "HWEP": {
                "type": "integer",
                "minimum": 0,
                "maximum": 65535,
                "description": "AY-3-8910/YM2149 HW Envelope Period (レジスタ0x0B Fine + 0x0C Coarse の16bit値、分割不可の単一パラメータ)。HW EG (EGT bit3) 使用時のみ有効。"
              }
            }
          },
          "FB2": {
            "type": "integer",
            "minimum": 0,
            "maximum": 7,
            "description": "OPL3(COPL3) 4OPモード専用: 後半ペア(M2/C2)独立のフィードバック値。実機OPL3は前半・後半ペアそれぞれ独立したFBレジスタを持つ。OPL3以外のチップでは未使用(0固定)。"
          }
        }
      }
    }
  },
  "examples": [
    {
      "name": "OPM Strings",
      "chip_group": "OPM",
      "patches": [
        {
          "prog": 0,
          "name": "Strings 1",
          "FB": 2,
          "ALG": 4,
          "AMS": 0,
          "PMS": 0,
          "NFQ": 0,
          "ops": [
            {
              "AR": 20,
              "DR": 10,
              "SL": 3,
              "SR": 5,
              "RR": 7,
              "TL": 24,
              "KSR": 0,
              "MUL": 1,
              "DT1": 3,
              "AM": 0
            },
            {
              "AR": 31,
              "DR": 8,
              "SL": 4,
              "SR": 4,
              "RR": 7,
              "TL": 20,
              "KSR": 0,
              "MUL": 2,
              "DT1": 0,
              "AM": 0
            },
            {
              "AR": 24,
              "DR": 12,
              "SL": 2,
              "SR": 6,
              "RR": 6,
              "TL": 30,
              "KSR": 0,
              "MUL": 1,
              "DT1": 7,
              "AM": 0
            },
            {
              "AR": 28,
              "DR": 6,
              "SL": 5,
              "SR": 3,
              "RR": 8,
              "TL": 0,
              "KSR": 0,
              "MUL": 1,
              "DT1": 0,
              "AM": 0
            }
          ]
        }
      ]
    }
  ]
}
