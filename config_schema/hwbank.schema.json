{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "fitom-hwbank",
  "title": "FITOM HW パッチバンク (*.hwbank.json)",
  "description": "チップレジスタへ直接書き込むパラメータのバンク。チップ族ごとに独立したファイルで管理する。",
  "type": "object",
  "required": [
    "name",
    "patches"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "バンク表示名"
    },
    "patches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "prog"
        ],
        "properties": {
          "prog": {
            "type": "integer",
            "minimum": 0,
            "maximum": 127
          },
          "name": {
            "type": "string"
          },
          "FB": {
            "type": "integer",
            "minimum": 0,
            "maximum": 7,
            "description": "Feedback"
          },
          "ALG": {
            "type": "integer",
            "minimum": 0,
            "maximum": 7,
            "description": "Algorithm。OPN/OPM: 3bit。OPL: 1bit。OPL3: bit0=CON1(前半ペア接続)/bit1=CON2(後半ペア接続)、bit2は未使用。4OP結合有効化フラグ(ConnectionSEL)はext.ALG_EXTに分離して持つ(2026年7月に訂正)。"
          },
          "AMS": {
            "type": "integer",
            "minimum": 0,
            "maximum": 3,
            "description": "AM Sensitivity (OPM)"
          },
          "PMS": {
            "type": "integer",
            "minimum": 0,
            "maximum": 7,
            "description": "PM Sensitivity (OPM)"
          },
          "NFQ": {
            "type": "integer",
            "minimum": 0,
            "maximum": 31,
            "description": "Noise Frequency (OPM)"
          },
          "ops": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "items": {
              "type": "object",
              "properties": {
                "AR": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 31
                },
                "DR": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 31
                },
                "SL": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 15
                },
                "SR": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 31
                },
                "RR": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 15
                },
                "TL": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 127
                },
                "KSR": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 3
                },
                "KSL": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 3
                },
                "MUL": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 15
                },
                "DT1": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 7
                },
                "DT2": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 3
                },
                "AM": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1
                },
                "VIB": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1
                },
                "EGT": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 15,
                  "description": "SSG-EG (OPN)"
                },
                "WS": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 127,
                  "description": "Wave Select。チップにより意味・実際の値域が異なる(型は共通の7bit幅、2026年7月にmaximumを7→127へ拡大): OPL2=2bit(0-3)、OPL3/OPZ=3bit(0-7)、OPM=0固定、SCC/SCC+=7bit(0-127、波形メモリへの直接インデックス)、AY8930(EPSG)=4bit(0-15、デューティ比として転用、波形メモリとは無関係)。"
                },
                "FXV": {
                  "type": "integer",
                  "minimum": -32768,
                  "maximum": 32767,
                  "description": "疑似デチューン/拡張周波数オフセット用パラメータ(100/64セント単位、getFnumber()にそのまま渡せる)。2箇所で使われる: ①OPN ch2 FXモード(3rd channel special mode)専用。ext.DM0でモード選択(モード1/2=疑似デチューン/非整数倍率、モード3=0.1Hz単位の絶対周波数)。②OPL3(COPL3)の4OP疑似デチューン(op[0]/op[2]、2026年7月〜。旧FITOMのDT1+DT2ビット合成(±8192)より広いレンジ(±32767)を持つ、OPNのFXモードと共通の仕組み)。上記以外のチップ/チャンネルでは無視される。"
                },
                "REV": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 15,
                  "description": "Reverberation: 4bit (OPZのみ、オペレータ単位)"
                },
                "EGS": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 127,
                  "description": "EG bias: 7bit (OPZのみ、オペレータ単位)"
                },
                "DT3": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 15,
                  "description": "Fine frequency: 4bit OPZ ratio mode (OPZのみ、オペレータ単位)"
                }
              }
            },
            "description": "オペレータパラメータの配列。要素数はチップのオペレータ数に応じて1〜4で可変(1=SSG/DCSG/SAA/SCC等、2=OPL/OPL2/OPL3_2/OPLL系、4=OPN/OPN2/OPM/OPZ/OPZ2/OPL3(4opモード))。正確な対応はdocs/chip-driver-architecture.mdの「5. VoicePatchType 対応表」参照。指定した要素数分だけ読み込まれ、残りはデフォルト値のまま扱われる(PatchManager::jsonToHwPatch参照)。ADPCM/AWM系はHwPatchを使わない(SampleZonePatchを使う別スキーマ)ため対象外。"
          },
          "ext": {
            "type": "object",
            "description": "チップ固有拡張パラメータ (OPZ / PSG 等)",
            "properties": {
              "DM0": {
                "type": "integer",
                "minimum": 0,
                "maximum": 3,
                "description": "OPZ: Osc fixed freq flag(1bit相当、0/1)。OPN ch2: FXモード選択 (0=通常/1=疑似デチューン/2=非整数倍率/3=固定周波数)。他チップでは未使用。"
              },
              "ALG_EXT": {
                "type": "integer",
                "minimum": 0,
                "maximum": 1,
                "description": "ALG拡張ビット。OPM: noise有効化。OPLL: preset音色選択。OPL3: ConnectionSEL(4OP結合有効化、2026年7月に参照漏れを訂正)。いずれも1bit。"
              },
              "HWEP": {
                "type": "integer",
                "minimum": 0,
                "maximum": 65535,
                "description": "AY-3-8910/YM2149 HW Envelope Period (レジスタ0x0B Fine + 0x0C Coarse の16bit値、分割不可の単一パラメータ)。HW EG (EGT bit3) 使用時のみ有効。"
              },
              "target_voice_patch_type": {
                "type": "integer",
                "minimum": 0,
                "maximum": 255,
                "description": "PSG系共有バンク(voice_patch_type=0x40固定でロードされるバンク)専用。このパッチが実際に対象とするVoicePatchTypeの値(0x40=SSG/0x41=EPSG/0x42=DCSG/0x43=SAA/0x48=SCC)を指定する。0(デフォルト)=未設定、プロファイルのpsg_fallback_chipで指定されたチップにフォールバックする。PSG系以外のチップでは無視される。"
              },
              "rhythm_ch": {
                "type": "integer",
                "minimum": 0,
                "maximum": 255,
                "default": 255,
                "description": "voice_patch_type=0x23(VOICE_PATCH_OPL_RHY、COPLRhythm)専用。このパッチが対象とする物理チャンネル(=楽器)番号を指定する: 0=HH, 1=CYM, 2=TOM, 3=SD, 4=BD。255(デフォルト)=未設定であり、OPL_RHYで使う場合は指定必須(未設定のまま解決しようとすると発音失敗になる)。patch_prog(HwBank内の格納スロット番号)とは独立した軸であり、同じ楽器に複数の音色バリエーションを別スロットとして用意できる。OPL_RHY以外のチップでは無視される。"
              }
            }
          },
          "FB2": {
            "type": "integer",
            "minimum": 0,
            "maximum": 7,
            "description": "OPL3(COPL3) 4OPモード専用: 後半ペア(M2/C2)独立のフィードバック値。実機OPL3は前半・後半ペアそれぞれ独立したFBレジスタを持つ。OPL3以外のチップでは未使用(0固定)。"
          },
          "sw_bank": {
            "type": "integer",
            "minimum": -1,
            "maximum": 127,
            "default": -1,
            "description": "このHwPatch(音色データ)自身が指定するパフォーマンスパッチ(SwPatch)の参照先バンク番号。-1(省略時のデフォルト)=参照なし。DrumNote側の個別上書き(swBank/swProg)が優先される。指定先が解決できない場合はパフォーマンスパッチが適用されないだけで、HwPatch自体の発音は妨げられない。"
          },
          "sw_prog": {
            "type": "integer",
            "minimum": -1,
            "maximum": 127,
            "default": -1,
            "description": "sw_bankと組で使う、参照先のプログラム番号。"
          },
          "builtin": {
            "type": "object",
            "description": "OPLL ROM音色(内部生成、opllRomPatches_)への参照。このバンクが「builtin専用バンク」(profile.jsonのhw_banks[].role=\"builtin_swpatch_meta\"で指定)である場合のみ意味を持つ。prog番号による機械的な対応ではなく、パッチ設計者が明示的に指定するuser specificな識別子。opsとは排他(2026年7月新設、docs/patch-structure-design.md参照)。",
            "properties": {
              "patch_type": {
                "type": "string",
                "enum": [
                  "OPLL",
                  "OPLLX",
                  "OPLLP",
                  "VRC7"
                ],
                "description": "対象チップバリアント。PatchManager::kVariantMapと対応。"
              },
              "patch_no": {
                "type": "integer",
                "minimum": 1,
                "maximum": 15,
                "description": "ROM音色番号(1-15)。initOpllRomPatches()のkNames[][]参照。"
              }
            },
            "required": [
              "patch_type",
              "patch_no"
            ],
            "additionalProperties": false
          }
        },
        "oneOf": [
          {
            "required": [
              "ops"
            ]
          },
          {
            "required": [
              "builtin"
            ]
          }
        ],
        "description": "opsとbuiltinはどちらか一方が必須(排他)。builtinはOPLL ROM音色への参照専用で、通常のHwPatch(ops[]でFMパラメータを記述)とは異なる用途に使う。"
      }
    }
  },
  "examples": [
    {
      "name": "OPM Strings",
      "patches": [
        {
          "prog": 0,
          "name": "Strings 1",
          "FB": 2,
          "ALG": 4,
          "AMS": 0,
          "PMS": 0,
          "NFQ": 0,
          "ops": [
            {
              "AR": 20,
              "DR": 10,
              "SL": 3,
              "SR": 5,
              "RR": 7,
              "TL": 24,
              "KSR": 0,
              "MUL": 1,
              "DT1": 3,
              "AM": 0
            },
            {
              "AR": 31,
              "DR": 8,
              "SL": 4,
              "SR": 4,
              "RR": 7,
              "TL": 20,
              "KSR": 0,
              "MUL": 2,
              "DT1": 0,
              "AM": 0
            },
            {
              "AR": 24,
              "DR": 12,
              "SL": 2,
              "SR": 6,
              "RR": 6,
              "TL": 30,
              "KSR": 0,
              "MUL": 1,
              "DT1": 7,
              "AM": 0
            },
            {
              "AR": 28,
              "DR": 6,
              "SL": 5,
              "SR": 3,
              "RR": 8,
              "TL": 0,
              "KSR": 0,
              "MUL": 1,
              "DT1": 0,
              "AM": 0
            }
          ]
        }
      ]
    }
  ]
}
